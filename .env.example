# ============================================================================
# Crypto Bot Trading - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ============================================================================

# =========================
# Kraken API (REQUIRED)
# =========================
# Get credentials from: https://www.kraken.com/u/security/api
# Required permissions: Query Funds, Query Open Orders, Create/Cancel Orders
KRAKEN_API_KEY=your_api_key_here
KRAKEN_API_SECRET=your_api_secret_here

POSTGRES_USER=omni_bot
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=omni_bot
POSTGRES_PORT=5433
DATABASE_URL=postgresql://omni_bot:changeme_in_production@postgres:5432/omni_bot

# =========================
# Redis Configuration
# =========================
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6380
REDIS_MAX_CONNECTIONS=50

# =========================
# API Configuration
# =========================
API_HOST=0.0.0.0
API_PORT=8001
CORS_ORIGINS=http://localhost:3001,http://localhost:8080
LOG_LEVEL=INFO

# =========================
# Frontend Configuration
# =========================
FRONTEND_PORT=3001

# =========================
# Account & Risk Settings
# =========================
ACCOUNT_EQUITY=41.67
RISK_PCT_PER_TRADE=2.0
STOP_LOSS_PCT=5.0

# =========================
# Adaptive Trading System Configuration
# =========================
ADAPTIVE_ENABLED=true
TARGET_WIN_RATE=0.55
ADAPTIVE_CONFIDENCE_STEP=5.0
MIN_TRADES_FOR_EVALUATION=10
MIN_WIN_RATE_THRESHOLD=0.40
ADAPTIVE_SIZING_ENABLED=true
MAX_SIZE_MULTIPLIER=1.5
MIN_SIZE_MULTIPLIER=0.1
PROFITABILITY_TARGET_USD=1.0
PROFITABILITY_COOLDOWN_ENABLED=true
MAX_CONSECUTIVE_LOSSES=3
DAILY_LOSS_LIMIT=10.0

# =========================
# Screener Settings
# =========================
SCREENER_INTERVAL_SECONDS=60

# =========================
# Shadow-Live Mode (Pre-Live Validation)
# =========================
# When true: Logs ORDER_INTENT, STOP_INTENT, TAKE_PROFIT_INTENT without executing
# Used for pre-live validation (24-48 hours recommended)
# Keep TRADING_ENABLED=false when using shadow-live mode
SHADOW_LIVE_MODE=false

# =========================
# Ingestor Settings
# =========================
# Leave empty to auto-fetch top 20 USD pairs by volume
INGESTOR_SYMBOLS=
INGESTOR_INTERVALS=5m,15m,1h

# =========================
# Live Universe Restriction
# =========================
# Comma-separated list of symbols allowed for live trading
# Only these symbols will execute live trades (others evaluated in shadow mode only)
LIVE_UNIVERSE_PAIRS=BTC/USD,ETH/USD,SOL/USD,LINK/USD,DOT/USD
