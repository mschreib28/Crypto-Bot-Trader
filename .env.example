# Database Configuration
POSTGRES_USER=omni_bot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=omni_bot
POSTGRES_PORT=5432
DATABASE_URL=postgresql://omni_bot:changeme@postgres:5432/omni_bot

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
REDIS_MAX_CONNECTIONS=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
LOG_LEVEL=INFO

# Kraken API Credentials (required for execution)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Ingestor Configuration
INGESTOR_SYMBOLS=BTC/USD,ETH/USD
INGESTOR_INTERVALS=4h,1d
INGESTOR_HEALTH_FILE=/tmp/ingestor.health
